APP_NAME=Interview Agent API
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/interview_agent
REDIS_URL=redis://localhost:6379/0
CHROMA_PERSIST_DIRECTORY=./storage/chroma
UPLOAD_DIR=./storage/uploads
DB_AUTO_CREATE=false
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DEFAULT_CHAT_PROVIDER=qwen
DEFAULT_CHAT_MODEL=qwen3.6-plus-2026-04-02
DEFAULT_EMBEDDING_PROVIDER=qwen
DEFAULT_EMBEDDING_MODEL=text-embedding-v4
